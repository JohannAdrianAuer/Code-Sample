local function DeleteStrokes(frame, matchString, FindMethode)
	for _, button in ipairs(frame:GetChildren()) do
		if button:IsA("ImageButton") then
			if FindMethode == "Find" then
				if button.Name:find(matchString, 1, true) then

					for _, stroke in ipairs(button:GetChildren()) do
						if stroke:IsA("UIStroke") then

							stroke:Destroy()
						end
					end
				end
			else
				if not button.Name:find(matchString, 1, true) then
					for _, stroke in ipairs(button:GetChildren()) do
						if stroke:IsA("UIStroke") then
							stroke:Destroy()
						end
					end
				end
			end
		end
	end
end

local function colorClose(r1,g1,b1, r2,g2,b2, tol)
	return math.abs(r1 - r2) <= tol
		and math.abs(g1 - g2) <= tol
		and math.abs(b1 - b2) <= tol
end

local function floodFill(editable, startX, startY, newR, newG, newB, newA)
	local size = editable.Size
	local width  = math.floor(size.X)
	local height = math.floor(size.Y)

	startX = math.floor(startX)
	startY = math.floor(startY)

	local RGB_TOL = 50
	local ALPHA_TOL = 5

	local visited = {}

	local buf = editable:ReadPixelsBuffer(Vector2.zero, size)
	local bufLen = buffer.len(buf)

	local startIndex = (startY * width + startX) * 4
	if startIndex < 0 or startIndex + 3 >= bufLen then return end

	local targetR = buffer.readu8(buf, startIndex)
	local targetG = buffer.readu8(buf, startIndex + 1)
	local targetB = buffer.readu8(buf, startIndex + 2)
	local targetA = buffer.readu8(buf, startIndex + 3)

	if targetR == newR and targetG == newG
		and targetB == newB and targetA == newA then
		return
	end

	local stack = { { startX, startY } }

	while #stack > 0 do
		local node = stack[#stack]
		stack[#stack] = nil
		local x, y = node[1], node[2]

		if x < 0 or x >= width or y < 0 or y >= height then
			continue
		end

		local key = y * width + x
		if visited[key] then continue end
		visited[key] = true

		local i = (y * width + x) * 4
		if i < 0 or i + 3 >= bufLen then continue end

		local r = buffer.readu8(buf, i)
		local g = buffer.readu8(buf, i + 1)
		local b = buffer.readu8(buf, i + 2)
		local a = buffer.readu8(buf, i + 3)

		if colorClose(r, g, b, targetR, targetG, targetB, RGB_TOL)
			and math.abs(a - targetA) <= ALPHA_TOL then

			buffer.writeu8(buf, i,     newR)
			buffer.writeu8(buf, i + 1, newG)
			buffer.writeu8(buf, i + 2, newB)
			buffer.writeu8(buf, i + 3, newA)

			stack[#stack+1] = { x+1, y }
			stack[#stack+1] = { x-1, y }
			stack[#stack+1] = { x, y+1 }
			stack[#stack+1] = { x, y-1 }
		end
	end

	editable:WritePixelsBuffer(Vector2.zero, size, buf)
end

local function plot(img, x, y, color)
	img:DrawRectangle(Vector2.new(x, y), Vector2.new(1,1), color, 1, Enum.ImageCombineType.Overwrite)
end


local function stamp(img, cx, cy, r, color)
	for x = -r, r do
		for y = -r, r do
			if x*x + y*y <= r*r then
				plot(img, cx + x, cy + y, color)
			end
		end
	end
end



local function drawThickLine(img, p1, p2, thickness, color)

	local x1 = math.floor(p1.X+0.5)
	local y1 = math.floor(p1.Y+0.5)
	local x2 = math.floor(p2.X+0.5)
	local y2 = math.floor(p2.Y+0.5)

	local dx = math.abs(x2-x1)
	local dy = math.abs(y2-y1)

	local sx = x1 < x2 and 1 or -1
	local sy = y1 < y2 and 1 or -1
	local err = dx - dy

	local r = math.floor(thickness/2)

	while true do
		stamp(img, x1, y1, r, color)

		if x1 == x2 and y1 == y2 then break end

		local e2 = err*2
		if e2 > -dy then err -= dy; x1 += sx end
		if e2 < dx then err += dx; y1 += sy end
	end
end


